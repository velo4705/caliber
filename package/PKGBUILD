# Maintainer: Caliber <caliber@example.com>
pkgname=caliber
pkgver=1.1.0
pkgrel=1
pkgdesc="Graphical calculator — Basic, Scientific, Programming, Graphing and more"
arch=('x86_64')
url="https://github.com/imloafy/caliber"
license=('MIT')
depends=('qt6-base' 'qt6-charts' 'qt6-datavis3d')
makedepends=('cmake' 'ninja')
source=("$pkgname-$pkgver.tar.gz::https://github.com/imloafy/caliber/archive/refs/tags/v$pkgver.tar.gz")
sha256sums=('SKIP')  # replace with actual sha256 after tagging the release

build() {
    cmake -S "$pkgname-$pkgver" -B build \
        -DCMAKE_BUILD_TYPE=Release \
        -DCMAKE_INSTALL_PREFIX=/usr \
        -GNinja
    cmake --build build
}

package() {
    DESTDIR="$pkgdir" cmake --install build
}
